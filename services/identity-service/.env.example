# Local Docker configuration contract. Create the ignored .env deliberately.
POSTGRES_DB=eventa_identity
POSTGRES_USER=eventa_identity
POSTGRES_PASSWORD=eventa_identity_password
DATABASE_URL=postgres://eventa_identity:eventa_identity_password@identity-database:5432/eventa_identity
TEST_DATABASE_URL=postgres://eventa_identity:eventa_identity_password@127.0.0.1:55432/eventa_identity_test
GRPC_HOST=0.0.0.0
GRPC_PORT=50051
HEALTH_PORT=3005
