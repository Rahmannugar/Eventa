# Local Docker configuration contract. Create the ignored .env deliberately.
POSTGRES_DB=eventa_notification
POSTGRES_USER=eventa_notification
POSTGRES_PASSWORD=eventa_notification_password
DATABASE_URL=postgres://eventa_notification:eventa_notification_password@notification-database:5432/eventa_notification
TEST_DATABASE_URL=postgres://eventa_notification:eventa_notification_password@127.0.0.1:56432/eventa_notification_test
RABBITMQ_URL=amqp://eventa:eventa_password@job-queue:5672
TEST_RABBITMQ_URL=amqp://eventa:eventa_password@127.0.0.1:5673
RABBITMQ_CONNECT_TIMEOUT_MS=2000
RABBITMQ_PUBLISH_TIMEOUT_MS=2000
RESEND_API_KEY=
RESEND_FROM="Eventa <onboarding@resend.dev>"
RESEND_REQUEST_TIMEOUT_MS=5000
HEALTH_PORT=3006
DEPLOYMENT_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://observability-collector:4318
