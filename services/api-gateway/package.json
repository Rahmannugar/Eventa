{
  "name": "@eventa/api-gateway",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nest build",
    "lint": "eslint src test --max-warnings 0",
    "start": "node dist/main.js",
