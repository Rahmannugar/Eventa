# Local Docker configuration contract. Create the ignored .env deliberately.
PORT=3004
API_DOCS_ENABLED=true
PUBLIC_API_URL=http://localhost:3004
HTTP_HEADERS_TIMEOUT_MS=10000
HTTP_REQUEST_TIMEOUT_MS=15000
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
IDENTITY_GRPC_URL=identity-service:50051
IDENTITY_GRPC_DEADLINE_MS=3000
REDIS_URL=redis://api-gateway-redis:6379
REDIS_CONNECT_TIMEOUT_MS=1000
REDIS_OPERATION_TIMEOUT_MS=750
TEST_REDIS_URL=redis://127.0.0.1:56379
RATE_LIMIT_KEY_SECRET=
TRUST_PROXY_HOPS=0
DEPLOYMENT_ENVIRONMENT=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://observability-collector:4318
